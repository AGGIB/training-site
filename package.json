{
  "name": "podgotovka-exam-trainer",
  "version": "1.0.0",
  "private": true,
  "description": "Java exam trainer RU/KZ with statistics and mistake correction",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "node --import tsx scripts/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "2.4.3",
    "jszip": "3.10.1",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jszip": "3.4.1",
    "@types/node": "22.10.2",
    "@types/react": "18.3.14",
    "@types/react-dom": "18.3.5",
    "prisma": "5.22.0",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
