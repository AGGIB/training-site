generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AttemptMode {
  VARIANT
  MIXED
}

enum Subject {
  JAVA
  ARDUINO
}

model User {
  id            String               @id @default(cuid())
  username      String               @unique
  passwordHash  String
  createdAt     DateTime             @default(now())
  sessions      Session[]
  attempts      Attempt[]
  progresses    UserQuestionProgress[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Variant {
  id        Int        @id
  subject   Subject    @default(JAVA)
  number    Int
  title     String
  questions Question[]

  @@unique([subject, number])
  @@index([subject])
}

model Question {
  id            String               @id @default(cuid())
  variantId     Int
  subject       Subject              @default(JAVA)
  order         Int
  text          String
  createdAt     DateTime             @default(now())
  variant       Variant              @relation(fields: [variantId], references: [id], onDelete: Cascade)
  options       Option[]
  attemptAnswers AttemptAnswer[]
  attemptLinks  AttemptQuestion[]
  progresses    UserQuestionProgress[]

  @@unique([variantId, order])
  @@index([variantId])
  @@index([subject, variantId])
}

model Option {
  id            String         @id @default(cuid())
  questionId    String
  label         String
  text          String
  isCorrect     Boolean
  order         Int
  question      Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  attemptAnswers AttemptAnswer[]
  mistakeAnswers MistakeAnswer[]

  @@unique([questionId, label])
  @@index([questionId])
}

model Attempt {
  id            String         @id @default(cuid())
  userId        String
  mode          AttemptMode
  subject       Subject        @default(JAVA)
  variantNumber Int?
  startedAt     DateTime       @default(now())
  finishedAt    DateTime?
  elapsedSec    Int?
  totalQuestions Int
  correctCount  Int            @default(0)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers       AttemptAnswer[]
  questions     AttemptQuestion[]

  @@index([userId])
  @@index([startedAt])
}

model AttemptQuestion {
  attemptId  String
  questionId String
  order      Int
  attempt    Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([attemptId, questionId])
  @@index([questionId])
}

model AttemptAnswer {
  id               String    @id @default(cuid())
  attemptId         String
  questionId        String
  selectedOptionId  String
  isCorrect         Boolean
  answeredAt        DateTime  @default(now())
  attempt           Attempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question          Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption    Option    @relation(fields: [selectedOptionId], references: [id])

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}

model UserQuestionProgress {
  id            String         @id @default(cuid())
  userId         String
  questionId     String
  streak         Int            @default(0)
  isActive       Boolean        @default(false)
  timesWrong     Int            @default(0)
  timesCorrect   Int            @default(0)
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  question       Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  mistakeAnswers MistakeAnswer[]

  @@unique([userId, questionId])
  @@index([userId, isActive])
}

model MistakeAnswer {
  id               String              @id @default(cuid())
  userProgressId   String
  selectedOptionId String
  isCorrect        Boolean
  answeredAt       DateTime            @default(now())
  userProgress     UserQuestionProgress @relation(fields: [userProgressId], references: [id], onDelete: Cascade)
  selectedOption   Option              @relation(fields: [selectedOptionId], references: [id])

  @@index([userProgressId])
}
